model "zen_rounding" {}

# Ported from zen expression standard.csv rounding rows:
#   round(7.555, 2) => 7.56   (line 469)
#   round(7.444, 1) => 7.4    (line 465)
#   trunc(7.6)      => 7      (line 475)
#   floor(4.8)      => 4      (line 98)
#   ceil(4.1)       => 5      (line 99)
# Each exposed as a separate scalar decision driven by one input x.
input x : number

# round to 2 decimals (zen round(x,2))
decision r2 : number = round(x, 2)
# round to 1 decimal (zen round(x,1))
decision r1 : number = round(x, 1)
# truncate toward zero (zen trunc)
decision tr : number = trunc(x)
# floor / ceiling (zen floor / ceil)
decision fl : number = floor(x)
decision ce : number = ceiling(x)
