model "loan_drg" {}

# Loan DRG: BKM (inlined) -> ratio -> band -> approval. Exact-decimal division.
input debt   : number in [0..1000000]
input income : number in [1..1000000]
input score  : number in [300..850]

bkm dti(d:number, i:number):number = d / (i / 12)

decision ratio : number = dti(debt, income)

decision band : string {
  needs: score
  hit: first
  >= 720     => "prime"
  [640..720) => "near"
  default    => "subprime"
}

decision approved : boolean {
  needs: ratio, band
  hit: first
  <= 0.43 | "prime" => true
  <= 0.36 | "near"  => true
  -       | -       => false
}
