model "jsonlogic_modulo" {}

# Ports json-logic `%`:
#   {"%": [{"var":"a"}, {"var":"b"}]}
# logic.js uses JS `%` (truncated remainder); feelc `modulo` is floored (DMN). For non-negative
# operands these agree, e.g. 7 % 3 = 1, 101 % 2 = 1. We test the "is even?" idiom: a % 2 == 0.

input a : number >= 0
input b : number > 0

decision rem    : number  = modulo(a, b)
decision is_even: boolean = modulo(a, 2) = 0
