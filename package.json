{
  "name": "feelc-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for feelc's JavaScript/TypeScript packages (the Go engine + docs live alongside).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxgfr/feelc"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w feelc",
    "test": "npm run test -w feelc",
    "build:wasm": "make wasm",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "semantic-release": "^24.2.9"
  }
}
