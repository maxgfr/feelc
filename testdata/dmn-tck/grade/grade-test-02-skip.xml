<?xml version="1.0" encoding="UTF-8"?>
<!-- Out-of-subset case: the expected value is of type time (not supported by feelc; date and
     duration ARE supported, cf. ADR 0014). The harness must SKIP it with a reason, neither count it
     as a failure nor silently conform. -->
<testCases xmlns="http://www.omg.org/spec/DMN/20160719/testcase"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <testCase id="grade-time-skip">
    <inputNode name="score"><value xsi:type="xsd:integer">50</value></inputNode>
    <resultNode name="grade"><expected><value xsi:type="xsd:time">10:30:00</value></expected></resultNode>
  </testCase>
</testCases>
