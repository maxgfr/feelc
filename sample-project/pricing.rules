model "pricing" {
  rounding: half_even
}

input amount    : number >= 0
input threshold : number >= 0

type Tier = context { label: string, surcharge: number }

# An independent module: a decision table with a cross-column cell (`>= threshold`) and a
# multi-output context result. Namespaced to `pricing__tier` in the merged project.
decision tier : Tier {
  needs: amount, threshold
  hit: first
  #  amount       | threshold => label  | surcharge
     >= threshold | -         => "high" | 10
     default      |           => "low"  | 0
}
