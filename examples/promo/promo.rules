model "promo" {}

input cart_total : number >= 0
input is_member  : boolean
input promo_code : string

# Keep the BEST applicable discount (COLLECT C>, max).
decision discount_pct : number {
  needs: cart_total, is_member, promo_code
  hit: collect max
  #  cart_total | is_member | promo_code  => discount %
     >= 50      | -         | -           => 5
     >= 100     | -         | -           => 10
     -          | true      | -           => 8
     -          | -         | "WELCOME10" => 10
     -          | -         | "BIG20"     => 20
}
