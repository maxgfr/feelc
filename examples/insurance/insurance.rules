model "insurance" {
  rounding: half_even
}

input age          : number in [18..100]
input region       : string in {"urban", "suburban", "rural"}
input claims       : number >= 0
input base_premium : number >= 0

# Cumulative risk surcharges -> sum (COLLECT C+).
decision surcharge : number {
  needs: age, region, claims
  hit: collect sum
  #  age      | region  | claims => amount
     [18..25) | -       | -      => 300
     -        | "urban" | -      => 150
     -        | -       | >= 3   => 500
     >= 70    | -       | -      => 200
}

# Final premium = base + surcharge (DRG: premium depends on surcharge).
decision premium : number = base_premium + surcharge
